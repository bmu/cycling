# SQLite runtime databases (and WAL/SHM sidecars).
# NOTE: `data/` would otherwise swallow the project SOURCE data dirs
# (e.g. demo-fake-front-door/data/demo_data.py, semantic-studio/data/*.json),
# silently ignoring newly added seed/importable example data. Re-include those
# source trees explicitly; the *.db* rules below keep runtime databases ignored
# even inside them.
data/
!projects/semantic-studio/data/
!projects/semantic-studio/data/**
!projects/demo-fake-front-door/data/
!projects/demo-fake-front-door/data/**
*.db
*.db-journal

# LibreOffice lock files
.~lock.*#
*.db-wal
*.db-shm
